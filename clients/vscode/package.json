{
  "name": "devradar-vscode",
  "displayName": "devradar — kim online",
  "description": "Hangi takım arkadaşın şu an aynı repoda kod yazıyor — IDE'den bağımsız presence",
  "version": "0.1.0",
  "publisher": "mertkont",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/mertkont/devradar.git"
  },
  "bugs": {
    "url": "https://github.com/mertkont/devradar/issues"
  },
  "homepage": "https://github.com/mertkont/devradar#readme",
  "keywords": ["presence", "team", "collaboration", "status", "online"],
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "devradar",
      "properties": {
        "devradar.serverUrl": {
          "type": "string",
          "default": "wss://devradar.mrt-kntt53.workers.dev/ws",
          "description": "devradar WebSocket sunucu adresi (genelde değiştirmene gerek yok)"
        },
        "devradar.displayName": {
          "type": "string",
          "default": "",
          "description": "Görünecek isim. Boş bırakılırsa git'teki adın (user.name) otomatik kullanılır."
        },
        "devradar.teamKey": {
          "type": "string",
          "default": "",
          "description": "Opsiyonel gizlilik anahtarı. Aynı repodaki herkes aynı değeri girerse, repo adresini bilen yabancılar odaya giremez. Boş bırakılabilir — repo adresi tek başına eşleştirme için yeterli."
        }
      }
    },
    "commands": [
      { "command": "devradar.showPeers", "title": "devradar: Kimler online?" },
      { "command": "devradar.reconnect", "title": "devradar: Yeniden bağlan" }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "vscode:prepublish": "tsc -p .",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "~1.96.0",
    "@types/ws": "^8.5.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.0"
  }
}
