{
  "name": "devradar-vscode",
  "displayName": "devradar — who's online",
  "description": "See which teammate is coding in the same git repo right now — IDE-agnostic developer presence + 1-to-1 chat",
  "version": "0.2.2",
  "publisher": "MertKont",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/mertkont/devradar.git"
  },
  "bugs": {
    "url": "https://github.com/mertkont/devradar/issues"
  },
  "homepage": "https://github.com/mertkont/devradar#readme",
  "keywords": ["presence", "team", "collaboration", "status", "online"],
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": ["Other"],
  "icon": "icon.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "devradar",
      "properties": {
        "devradar.serverUrl": {
          "type": "string",
          "default": "wss://devradar.mrt-kntt53.workers.dev/ws",
          "description": "devradar WebSocket server URL (you usually don't need to change this)"
        },
        "devradar.displayName": {
          "type": "string",
          "default": "",
          "description": "Display name. If empty, your git user.name is used automatically."
        },
        "devradar.teamKey": {
          "type": "string",
          "default": "",
          "description": "Optional privacy key. If everyone in the same repo enters the same value, outsiders who know the repo URL cannot join the room. Can be left empty — the repo URL alone is enough for matching."
        }
      }
    },
    "commands": [
      { "command": "devradar.showPeers", "title": "devradar: Who's online?" },
      { "command": "devradar.reconnect", "title": "devradar: Reconnect" },
      { "command": "devradar.openChat", "title": "devradar: Open chat" }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "vscode:prepublish": "tsc -p .",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "~1.96.0",
    "@types/ws": "^8.5.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.0"
  }
}
